# Create .env from this file. Never commit .env or an Airtable personal access token.
AIRTABLE_PAT=replace-with-a-newly-rotated-airtable-pat
SESSION_SECRET=replace-with-a-long-random-secret

# Required for the shareable read-only demo API. Send it as the X-API-Key header.
RATE_NINJA_API_KEY=replace-with-a-separate-demo-api-key

# These identifiers are not secrets, but keeping them configurable makes the app portable.
AIRTABLE_BASE_ID=appBLegnJMAienppq
AIRTABLE_RATE_TABLE_ID=tbl5OpIdW2kyRRWLp
AIRTABLE_USER_TABLE_ID=tblwtjp73CaWe3GKy
AIRTABLE_COMPANY_TABLE_ID=CompanyReference
AIRTABLE_SAILINGS_TABLE_ID=Sailings
